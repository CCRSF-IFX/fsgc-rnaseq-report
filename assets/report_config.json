          "labeling",
          "lambda.r",
          "lattice",
          "lifecycle",
          "rlang",
          "scales",
          "snow",
          "vctrs",
          "viridisLite",
          "withr"
        ],
        "memoryWarning": "medium",
        "experimental": true
