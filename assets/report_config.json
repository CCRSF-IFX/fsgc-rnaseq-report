        "description": "Versioned documentation for report v0.1.0."
      },
      {
        "label": "webR package snapshot",
        "version": "v0.1.0",
        "url": "https://ccrsf-ifx.github.io/fsgc-rnaseq-report/webr-packages/v0.1.0/",
        "description": "Compiled webR package repository used by browser DESeq2 and fgsea."
      }
    ]
  },
  "analysis": {
    "conditionColumn": "condition",
    "referenceLevel": "mock"
  },
  "ai": {
    "enabled": false,
    "provider": "openai-oauth-local",
    "baseUrl": "http://127.0.0.1:10531/v1",
    "model": "",
    "maxTokens": 900
  },
  "qcThresholds": {
    "mapping_rate": {
      "min_warn": 0.9,
      "min_fail": 0.8
    },
    "duplication_rate": {
      "max_warn": 0.3,
      "max_fail": 0.45
    },
    "rrna_rate": {
      "max_warn": 0.05,
      "max_fail": 0.1
    },
    "detected_genes": {
      "min_warn": 13000,
      "min_fail": 10000
    }
  },
  "webr": {
    "enabled": true,
    "baseUrl": "https://webr.r-wasm.org/v0.5.9/",
    "packageRepo": "https://ccrsf-ifx.github.io/fsgc-rnaseq-report/webr-packages/v0.1.0/",
    "packageRepoVersion": "v0.1.0",
    "packageArchiveUrl": "https://github.com/CCRSF-IFX/fsgc-rnaseq-report/releases/download/rnaseq-report-webr-packages-v0.1.0/rnaseq-report-webr-packages-v0.1.0.zip",
    "libraryBundle": {
      "enabled": true,
      "version": "v0.1.0",
      "artifactStem": "rnaseq-report-webr-library",
      "archiveFile": "rnaseq-report-webr-library-v0.1.0.zip",
      "releaseTag": "rnaseq-report-webr-library-v0.1.0",
      "releaseUrl": "https://github.com/CCRSF-IFX/fsgc-rnaseq-report/releases/tag/rnaseq-report-webr-library-v0.1.0"
    },
    "modules": {
      "deseq2": {
        "enabled": true,
        "packages": [
          "DESeq2",
          "S4Vectors",
          "IRanges",
          "GenomicRanges",
          "SummarizedExperiment",
          "BiocGenerics",
          "Biobase",
          "BiocParallel",
          "MatrixGenerics",
          "Seqinfo",
          "S4Arrays",
          "DelayedArray",
          "SparseArray",
          "XVector",
          "BH",
          "Matrix",
          "R6",
          "RColorBrewer",
          "Rcpp",
          "RcppArmadillo",
          "S7",
          "abind",
          "cli",
          "codetools",
          "cpp11",
          "farver",
          "formatR",
          "futile.logger",
          "futile.options",
          "generics",
          "ggplot2",
          "glue",
          "gtable",
          "isoband",
          "labeling",
          "lambda.r",
          "lattice",
          "lifecycle",
          "locfit",
          "matrixStats",
          "rlang",
          "scales",
          "snow",
          "vctrs",
          "viridisLite",
          "withr"
        ],
        "memoryWarning": "high",
        "experimental": true
      },
      "fgsea": {
        "enabled": true,
        "packages": [
          "fgsea",
          "BiocParallel",
          "BH",
          "Matrix",
          "R6",
          "RColorBrewer",
          "Rcpp",
          "S7",
          "cli",
          "codetools",
          "cowplot",
          "cpp11",
