    "versionsIndexUrl": "https://ccrsf-ifx.github.io/fsgc-rnaseq-report/docs/versions.json",
    "versionLinks": [
      {
        "label": "Hosted report",
        "version": "v0.1.0",
        "url": "https://ccrsf-ifx.github.io/fsgc-rnaseq-report/",
        "description": "Current hosted GSE164073 RNA-seq report."
      },
      {
        "label": "Documentation",
        "version": "latest",
        "url": "https://ccrsf-ifx.github.io/fsgc-rnaseq-report/docs/latest/",
        "description": "Latest user and developer documentation."
      },
      {
        "label": "Documentation",
        "version": "v0.1.0",
